# SEOBetter Cloud API — Environment Variables
# Copy this file to .env and fill in your keys

# AI Provider (at least one required)
# Groq is FREE — get key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: Anthropic Claude (higher quality, paid)
# Get key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: OpenAI (paid)
# Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Pro license keys (comma-separated)
# Users who purchased Pro at seobetter.com
SEOBETTER_PRO_KEYS=SEOBETTER-TEST-PRO-KEY
